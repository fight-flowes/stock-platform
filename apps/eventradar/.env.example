# eventradar — scratch values; copy to .env to override.
# Everything has sensible defaults in eventradar/config.py; this file only
# exists to document the knobs.

# Where DuckDB files and raw_cache live. Default: ./data/
# EVENTRADAR_DATA_DIR=

# Primary write file. Default: ${EVENTRADAR_DATA_DIR}/eventradar.duckdb
# EVENTRADAR_DUCKDB_PATH=

# Read replica file (the FastAPI server reads from this).
# Default: ${EVENTRADAR_DATA_DIR}/eventradar.read.duckdb
# EVENTRADAR_DUCKDB_READ_PATH=

# Raw upstream parquet cache. Default: ${EVENTRADAR_DATA_DIR}/raw_cache
# EVENTRADAR_RAW_CACHE_DIR=
# EVENTRADAR_RAW_CACHE_ENABLED=true

# Network defaults shared by every adapter.
# EVENTRADAR_HTTP_TIMEOUT=30
# EVENTRADAR_HTTP_MAX_RETRIES=3
# EVENTRADAR_HTTP_PROXY=

# FastAPI server.
# EVENTRADAR_API_HOST=0.0.0.0
# EVENTRADAR_API_PORT=8050
